# --- Database ---
# When using the dev docker-compose, this works as-is.
# (Port 5433 to avoid colliding with a system Postgres on 5432.)
DATABASE_URL=postgres://beamterminal:beamterminal@localhost:5433/beamterminal

# --- Explorer ---
# Dev: hit a public mainnet explorer
EXPLORER_URL=https://explorer.0xmx.net/api
# Prod: hit the local explorer-node
# EXPLORER_URL=http://localhost:8888

# --- Contracts (mainnet, verified live 2026-05-16) ---
DEX_CID=729fe098d9fd2b57705db1a05a74103dd4b891f535aef2ae69b47bcfdeef9cbf
# Block height the DEX contract was deployed at. Optional but recommended:
# avoids an explorer roundtrip on first backfill and works even when the
# explorer's /contracts listing drops the entry.
DEX_DEPLOY_HEIGHT=2270704
ORACLE_CID=4f160f01dcc6751e61d793279b803328d5332125fe8492e93ee8f3bfe9abe13b
# Beam Asset Minter. Optional — enables per-asset max-supply enrichment by
# reading the contract's State.Tokens table. Leave unset to skip.
ASSET_MINTER_CID=295fe749dc12c55213d1bd16ced174dc8780c020f59cb17749e900bb0c15d868
# DApp Store registry contract (mainnet). Same value as
# beam-ui/ui/model/settings.cpp::getNetworkDappStoreCID(). Leave empty to
# disable the dapp-store subsystem.
DAPP_STORE_CID=e2d24b686e8d31a0fe97eade9cd23281e7059b74b5757bdb96c820ef9e2af41c

# --- Wallet API (asset-swaps subsystem; optional) ---
# JSON-RPC base URL for the BEAM wallet-api daemon. Required only if you want
# DEX-style asset-swap offers (`assets_swap_offers_list`) indexed — the
# explorer cannot serve these. With the bundled docker-compose, the wallet-api
# service listens on 127.0.0.1:10005.
# WALLET_API_URL=http://localhost:10005
# Poll cadence for asset-swap offers (ms). Gossip cadence makes <15s pointless.
ASSET_SWAP_POLL_MS=30000

# --- Indexer ---
CONFIRMATIONS=80
POLL_INTERVAL_MS=30000

# --- API ---
API_PORT=3000
API_HOST=127.0.0.1
# Per-IP rate limit (requests per minute). 0 disables.
RATE_LIMIT_PER_MIN=600

# --- Logging ---
LOG_LEVEL=info
NODE_ENV=development
